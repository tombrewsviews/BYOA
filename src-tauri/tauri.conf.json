{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kinetic Studio",
  "version": "0.1.0",
  "identifier": "app.kinetic.studio",
  "build": {
    "frontendDist": "../editor/dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run editor",
    "beforeBuildCommand": "npm run build:editor"
  },
  "app": {
    "windows": [
      {
        "title": "Kinetic Studio",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/KineticStudio/**",
          "$HOME/KineticStudio/**/.kinetic-studio/**",
          "$HOME/KineticStudio/**/assets/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/bin/yt-dlp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
