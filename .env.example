# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Recraft V4 Vector — https://www.recraft.ai/  (API settings)
RECRAFT_API_KEY=

# Anthropic API — for the Claude-emits-SVG provider.
# NOTE: a Claude Max subscription does NOT cover API usage; this is separate.
ANTHROPIC_API_KEY=

# Ollama — local models. Default endpoint shown; change if yours differs.
OLLAMA_BASE_URL=http://localhost:11434
# A code-capable model that can emit SVG markup, e.g. qwen2.5-coder:7b
OLLAMA_MODEL=qwen2.5-coder:7b
